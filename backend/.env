# SSH Configuration
SSH_HOST=your_signing_server_ip
SSH_PORT=your_ssh_port
SSH_USER=your_username
SSH_KEY=/path/to/your/ssh/private_key
SSH_PASSWORD=your_ssh_password

# Server Configuration
HOST=0.0.0.0
PORT=5174
DEBUG=True

# Security
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
DATABASE_URL=sqlite:///applications.db

# Certificate Paths
REMOTE_BASE_DIR=/home/kali/lab
REMOTE_TEMP_DIR=/home/kali/lab/temp_uploads
REMOTE_CLIENT_DIR=/home/kali/lab/client
SIGNING_SCRIPT_PATH=/home/kali/lab/sign_csr_with_pem.sh

# File Upload Settings
MAX_UPLOAD_SIZE=10485760  # 10MB
ALLOWED_EXTENSIONS=["csr", "pem", "crt", "key"]

# Logging
LOG_LEVEL=INFO
LOG_FILE=app.log
